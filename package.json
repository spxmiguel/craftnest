{
  "name": "craftserver",
  "version": "0.2.3",
  "description": "Minecraft Server Manager — create, manage and share servers with ease",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "preview-web": "vite",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-updater": "^6.3.9",
    "extract-zip": "^2.0.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.craftserver.app",
    "productName": "CraftServer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "asar": true,
    "afterSign": "build/notarize.cjs",
    "mac": {
      "category": "public.app-category.utilities",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "identity": null,
      "target": [
        {
          "target": "pkg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "pkg": {
      "scripts": "build/pkg-scripts",
      "allowAnywhere": true,
      "allowCurrentUserHome": true,
      "isRelocatable": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "spxmiguel",
      "repo": "CraftServer"
    }
  }
}
